# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Server
PORT=3000

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Note: Use the SERVICE ROLE key (not the anon key) for backend operations
# The service role key bypasses Row Level Security (RLS)

# Async Excel Import Queue (optional, but recommended for large files)
# Enable by setting REDIS_URL, or REDIS_HOST (+ optional REDIS_* vars)
# REDIS_URL=redis://:password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0

# Queue behavior
EXCEL_IMPORT_ASYNC_THRESHOLD=200
USER_IMPORT_WORKER_CONCURRENCY=3

# Application-level Redis cache (cache-aside pattern)
# Set CACHE_ENABLED=false to disable all caching without code changes (kill-switch)
CACHE_ENABLED=true
# Default cache TTL in seconds (used as fallback, individual endpoints override this)
CACHE_DEFAULT_TTL=300
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV="sandbox" # sandbox | live

# Paymob (optional second payment gateway)
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
# Optional override (defaults to https://accept.paymobsolutions.com)
PAYMOB_BASE_URL=
