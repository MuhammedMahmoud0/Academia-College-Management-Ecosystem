# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database_name

# JWT Secret (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Frontend URL (used for CORS and cookie origin control)
FRONTEND_URL=http://localhost:5173

# Server
PORT=3000

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Note: Use the SERVICE ROLE key (not the anon key) for backend operations
# The service role key bypasses Row Level Security (RLS)

# Firebase Admin SDK Configuration (for push notifications)
# Stringified JSON representation of the service account key
FIREBASE_SERVICE_ACCOUNT_KEY='{ "type": "service_account", "project_id": "...", "private_key": "...", "client_email": "..." }'

# ── BullMQ / Excel Import Queue Redis (Provider 1) ─────────────────────────
# Used exclusively by the async Excel import queue (BullMQ).
# REDIS_URL=redis://:password@host:port/0
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=
REDIS_DB=0

# Queue behavior
EXCEL_IMPORT_ASYNC_THRESHOLD=200
USER_IMPORT_WORKER_CONCURRENCY=3

# ── Application Cache Redis (Provider 2) ─────────────────────────────────────
# Separate Redis provider used exclusively for the cache-aside caching layer.
# Can be a different host, database, or plan from the BullMQ provider above.
CACHE_REDIS_URL=redis://:password@host:port/0
# CACHE_REDIS_HOST=localhost
# CACHE_REDIS_PORT=6379
# CACHE_REDIS_USERNAME=
# CACHE_REDIS_PASSWORD=
CACHE_REDIS_DB=0

# Set CACHE_ENABLED=false to disable all caching without code changes (kill-switch)
CACHE_ENABLED=true
# Default cache TTL in seconds
CACHE_DEFAULT_TTL=300
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV="sandbox" # sandbox | live

# Paymob (optional second payment gateway)
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
# Optional override (defaults to https://accept.paymobsolutions.com)
PAYMOB_BASE_URL=
