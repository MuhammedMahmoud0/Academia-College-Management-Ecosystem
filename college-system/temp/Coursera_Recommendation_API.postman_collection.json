{
  "info": {
    "name": "Coursera Recommendation API",
    "description": "Postman collection to test the Course Summarization & Recommendation API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Recommendations",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"query\": \"Can you recommend 3 beginner courses for learning Python for Data Science?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://127.0.0.1:8000/recommend",
          "protocol": "http",
          "host": [
            "127",
            "0",
            "0",
            "1"
          ],
          "port": "8000",
          "path": [
            "recommend"
          ]
        },
        "description": "This endpoint sends a query to the recommendation model to get course suggestions."
      },
      "response": []
    }
  ]
}